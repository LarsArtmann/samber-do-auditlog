direction: down

title: {
  label: samber-do-auditlog — Ideal Target Architecture
  shape: text
  near: top-center
}

user: {
  label: User Code
  shape: rectangle
}

plugin_layer: {
  label: "Plugin Layer (plugin.go)"
  shape: rectangle

  config: {
    label: "Config\nEnabled: bool\nContainerID: string\nEventHandler: func(Event)\nValidate() error"
    shape: class
  }
  new: "New(config) *Plugin"
  opts: "Opts() *InjectorOpts"
}

recorder_layer: {
  label: "Event Recorder (recorder.go)"
  shape: rectangle

  hooks: {
    label: "Hook Callbacks\n(same 6 hooks)"
    shape: class
  }
  state: {
    label: "State\nevents, services, scopes, stack"
    shape: class
  }
}

report_builder: {
  label: "Report Builder (report_builder.go)"
  shape: rectangle

  build: {
    label: "BuildReport(opts ...ReportOption)\n — WithServiceFilter(name)\n — WithTimeRange(from, to)\n — WithEventTypes(types...)"
    shape: class
  }
  scope: "buildScopeTree()"
  deps: "buildDependencyGraph()"
}

event_streaming: {
  label: "Event Streaming (new)"
  shape: rectangle

  handler: {
    label: "EventHandler func(Event)\nReal-time callback\nfor live dashboards"
    shape: class
  }
}

types: {
  label: "Domain Types (types.go)"
  shape: rectangle

  event: {
    label: "Event + convenience methods\nIsRegistration() bool\nIsInvocation() bool\nIsShutdown() bool\nIsBefore() bool\nIsAfter() bool"
    shape: class
  }
  report: "Report (versioned schema)"
  service_info: "ServiceInfo"
  scope_node: "ScopeNode"
}

export: {
  label: "Export Layer"
  shape: rectangle

  json: "JSON"
  ndjson: "NDJSON"
  html: "HTML (templ)"
  future: "Mermaid?\nPlantUML?"
}

samber_do: "samber/do v2"

user -> plugin_layer.new: "creates"
plugin_layer.opts -> samber_do: "InjectorOpts"
samber_do -> recorder_layer.hooks: "hooks fire"
recorder_layer.hooks -> recorder_layer.state: "captures"
recorder_layer.hooks -> event_streaming.handler: "calls EventHandler\n(if configured)"
plugin_layer -> report_builder: "Report(opts...)"
report_builder -> recorder_layer.state: "reads"
report_builder -> types: "assembles"
types -> export: "exports"
