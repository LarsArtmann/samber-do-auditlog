direction: down

title: {
  label: samber-do-auditlog — Current Architecture
  shape: text
  near: top-center
}

user: {
  label: User Code
  shape: rectangle

  main: {
    label: "main()"
    shape: code
  }
}

plugin_layer: {
  label: "Plugin Layer (plugin.go)"
  shape: rectangle

  config: {
    label: "Config\nEnabled: bool\nContainerID: string"
    shape: class
  }
  new: {
    label: "New(config) *Plugin"
    shape: code
  }
  opts: {
    label: "Opts() *InjectorOpts"
    shape: code
  }
  report_api: {
    label: "Report() Report\nExportToFile()\nExportEventsToNDJSON()\nExportToHTML()\nWriteReportJSON()\nWriteEventsNDJSON()\nWriteHTML()"
    shape: class
  }
}

recorder_layer: {
  label: "Recorder Layer (recorder.go)"
  shape: rectangle

  hooks: {
    label: "Hook Callbacks\nOnBeforeRegistration\nOnAfterRegistration\nOnBeforeInvocation\nOnAfterInvocation\nOnBeforeShutdown\nOnAfterShutdown"
    shape: class
  }
  state: {
    label: "Internal State\nevents []Event\nservices map[string]*serviceRecord\nscopes map[string]scopeMeta\nstack []stackEntry"
    shape: class
  }
  locks: {
    label: "Concurrency\nmu (RWMutex) — events/services\nstackMu (Mutex) — invocation stack\ninvocationMu (Mutex) — ordering\nshutdownMu (Mutex) — shutdown timing"
    shape: class
  }
  builder: {
    label: "Report Builder\nBuildReport()\nbuildServicesLocked()\nbuildScopeTreeLocked()\nbuildDependentsMapLocked()"
    shape: class
  }
}

types: {
  label: "Domain Types (types.go)"
  shape: rectangle

  event: {
    label: "Event\nSequence, Timestamp\nEventType, Phase\nScopeID, ServiceName\nDurationMs, Error"
    shape: class
  }
  service_info: {
    label: "ServiceInfo\nInvocationCount, Order\nDependencies, Dependents\nShutdownAt, DurationMs\nErrors"
    shape: class
  }
  scope_node: {
    label: "ScopeNode\nID, Name\nServices, Children"
    shape: class
  }
  report: {
    label: "Report\nVersion, ContainerID\nServices, Events\nScopeTree"
    shape: class
  }
}

export: {
  label: "Export Formats"
  shape: rectangle

  json: {
    label: "JSON Report"
    shape: rectangle
  }
  ndjson: {
    label: "NDJSON Stream"
    shape: rectangle
  }
  html: {
    label: "HTML Visualization\n(html.templ)"
    shape: rectangle
  }
}

samber_do: {
  label: "samber/do v2"
  shape: rectangle

  injector: {
    label: "do.Injector\nwith InjectorOpts hooks"
    shape: code
  }
}

user.main -> plugin_layer.new: "creates Plugin"
plugin_layer.opts -> samber_do.injector: "InjectorOpts with hooks"
samber_do.injector -> recorder_layer.hooks: "lifecycle events"
recorder_layer.hooks -> recorder_layer.state: "captures"
recorder_layer.builder -> recorder_layer.state: "reads"
plugin_layer.report_api -> recorder_layer.builder: "BuildReport()"
recorder_layer.builder -> types.report: "assembles"
types.report -> export.json: "WriteReportJSON"
types.report -> export.ndjson: "WriteEventsNDJSON"
types.report -> export.html: "WriteHTML"
plugin_layer.config -> plugin_layer.new: "configures"
