---
import SectionHeader from './SectionHeader.astro';

const screenshots = [
  { src: '/images/html-services.jpg', alt: 'Services tab — waveform, stats cards, and service table with type badges, status indicators, and dependency columns', label: 'Services' },
  { src: '/images/html-graph.jpg', alt: 'Dependency Graph tab — interactive Sugiyama-layered DAG with type-colored nodes and pan/zoom controls', label: 'Dependency Graph' },
  { src: '/images/html-timeline.jpg', alt: 'Timeline tab — dual build and shutdown horizontal bars with type icons and durations', label: 'Timeline' },
  { src: '/images/html-events.jpg', alt: 'Events tab — chronological event log with type filter chips, provider badges, and phase icons', label: 'Events' },
];
---

<section class="pb-8">
  <SectionHeader title="What does it look like?" subtitle="One self-contained HTML file. No server, no runtime dependencies, no external requests." />

  <div class="grid gap-4 sm:gap-5 sm:grid-cols-2">
    {screenshots.map((shot, i) => (
      <a
        href={shot.src}
        target="_blank"
        rel="noopener"
        class="group relative rounded-xl border border-border bg-bg-card-solid overflow-hidden hover:border-accent/50 transition-all duration-200 shadow-lg"
      >
        <div class="flex items-center gap-1.5 px-4 py-2.5 border-b border-border bg-bg-code">
          <span class="w-2.5 h-2.5 rounded-full bg-code-dot"></span>
          <span class="w-2.5 h-2.5 rounded-full bg-code-dot"></span>
          <span class="w-2.5 h-2.5 rounded-full bg-code-dot"></span>
          <span class="ml-2 text-xs text-text-muted font-mono">{shot.label}</span>
          <span class="ml-auto text-text-muted opacity-0 group-hover:opacity-100 transition-opacity duration-200 text-xs font-mono">Click to enlarge</span>
        </div>
        <div class="relative overflow-hidden">
          <img
            src={shot.src}
            alt={shot.alt}
            class="w-full h-auto block transition-transform duration-300 group-hover:scale-[1.02]"
            loading={i < 2 ? 'eager' : 'lazy'}
            width="1400"
            height="1300"
          />
          <div class="absolute inset-0 bg-accent/0 group-hover:bg-accent/[0.03] transition-colors duration-300 pointer-events-none"></div>
        </div>
      </a>
    ))}
  </div>
</section>
