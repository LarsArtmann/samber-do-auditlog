---
import { siteConfig } from '../data/config';
import { heroCode } from '../data/hero-code';
import Icon from './Icon.astro';

async function getGitHubStars(): Promise<number | null> {
  try {
    const response = await fetch('https://api.github.com/repos/LarsArtmann/samber-do-auditlog', {
      headers: {
        'Accept': 'application/vnd.github.v3+json',
      },
    });
    if (!response.ok) return null;
    const data = await response.json();
    return data.stargazers_count as number;
  } catch {
    return null;
  }
}

const stars = await getGitHubStars();
const starsText = stars !== null && stars > 0 ? `${stars} Stars` : 'Star on GitHub';

const importPath = siteConfig.github.replace('https://github.com/', 'github.com/');

const highlightedCode = `<span class="text-text-muted">package</span> <span class="text-text-secondary">main</span>

<span class="text-text-muted">import</span> (
    <span class="text-amber">"os"</span>

    auditlog <span class="text-amber">"${importPath}"</span>
    <span class="text-amber">"github.com/samber/do/v2"</span>
)

<span class="text-text-muted">func</span> <span class="text-accent">main</span>() {
    plugin, err := auditlog.<span class="text-accent">New</span>(auditlog.Config{
        Enabled:     <span class="text-accent-hover">true</span>,
        ContainerID: <span class="text-amber">"my-app"</span>,
    })
    <span class="text-text-muted">if</span> err != <span class="text-accent-hover">nil</span> {
        <span class="text-text-muted">panic</span>(err)
    }

    injector := do.<span class="text-accent">NewWithOpts</span>(plugin.<span class="text-accent">Opts</span>())

    <span class="text-code-comment">// Register and invoke services as usual</span>
    do.<span class="text-accent">Provide</span>(injector, <span class="text-text-muted">func</span>(i do.Injector) (*Database, error) {
        <span class="text-text-muted">return</span> &amp;Database{}, <span class="text-accent-hover">nil</span>
    })
    do.<span class="text-accent">MustInvoke</span>[*Database](injector)

    <span class="text-code-comment">// Export when ready</span>
    plugin.<span class="text-accent">ExportToHTML</span>(<span class="text-amber">"audit.html"</span>)
    plugin.<span class="text-accent">Report</span>().<span class="text-accent">WriteMermaid</span>(os.Stdout)
}`;
---

<section class="relative flex items-center justify-center overflow-hidden pt-32 pb-16">
  <div class="absolute top-1/4 left-1/2 -translate-x-1/2 w-[800px] h-[400px] bg-accent/5 blur-[120px] rounded-full pointer-events-none"></div>
  <div class="relative max-w-3xl xl:max-w-6xl mx-auto px-6 text-center">
    <a class="inline-flex items-center gap-1.5 px-3.5 py-1.5 border border-border rounded-md text-text-secondary text-[0.8125rem] font-medium no-underline hover:border-accent hover:text-accent transition-all duration-150 mb-6" href={siteConfig.github} target="_blank" rel="noopener">
      <Icon name="star" size={14} />
      {starsText}
    </a>
    <h1 class="text-[clamp(3rem,8vw,4.5rem)] font-bold tracking-tighter leading-tight mb-6">
      <span>See every </span><span class="bg-gradient-to-r from-accent to-accent-light bg-clip-text text-transparent">dependency</span><span>, every event.</span>
    </h1>

    <p class="text-[clamp(1.125rem,2.5vw,1.25rem)] text-text-muted max-w-3xl mx-auto mb-10 leading-relaxed">
      Audit-log plugin for <em class="not-italic text-text-primary">samber/do v2</em>. Track every registration, invocation, and shutdown with timestamps, dependency graphs, and self-contained HTML visualization.
    </p>

    <div class="flex flex-col sm:flex-row items-center justify-center gap-4 mb-16">
      <a href="/getting-started/quick-start/" data-astro-prefetch class="px-6 py-3 bg-accent text-bg-primary font-semibold rounded-lg text-sm hover:bg-accent-hover transition-colors duration-150 inline-flex items-center gap-2 border-none cursor-pointer">Get Started &rarr;</a>
      <div class="flex items-center gap-2 py-2.5 px-4 rounded-lg bg-bg-card-solid border border-border font-mono text-sm text-text-primary select-all">$ go get {siteConfig.github.replace('https://github.com', 'github.com')}</div>
    </div>

    <div class="relative max-w-xl mx-auto">
      <div class="absolute -inset-4 bg-gradient-to-r from-accent/10 via-transparent to-accent/10 rounded-2xl blur-6 pointer-events-none"></div>
      <div class="relative rounded-xl border border-border bg-bg-code shadow-2xl overflow-hidden code-preview">
        <div class="flex items-center gap-1.5 px-4 py-3 border-b border-border">
          {Array(3).fill(null).map(() => (
            <span class="w-3 h-3 rounded-full bg-code-dot"></span>
          ))}
          <span class="ml-3 text-xs text-text-muted font-mono">main.go</span>
        </div>
        <pre class="p-4 text-left text-sm font-mono leading-relaxed overflow-x-auto relative"><code id="hero-code" set:html={highlightedCode} /></pre>
        <button class="absolute top-2 right-2 bg-code-inline-bg/80 border border-border rounded-md text-text-muted px-1.5 py-1.5 cursor-pointer text-xs font-mono hover:text-text-primary hover:border-border-hover transition-all duration-150 opacity-0 [.code-preview:hover_&]:opacity-100" id="copy-btn" data-code={heroCode} aria-label="Copy code to clipboard">Copy</button>
      </div>
    </div>
  </div>
</section>

<script is:inline src="/js/copy-code.js"></script>
