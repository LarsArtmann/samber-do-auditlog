---
export interface Props {
  width?: number;
  height?: number;
  class?: string;
}

const { width = 28, height = 28, class: className } = Astro.props;
---

<svg class={className} width={width} height={height} viewBox="0 0 28 28" fill="none" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="do-auditlog logo">
  <rect width="28" height="28" rx="6" class="fill-[var(--color-accent)]" />
  <path d="M14 6.5L8.5 9.5V14C8.5 17.5 10.8 20.7 14 21.8C17.2 20.7 19.5 17.5 19.5 14V9.5L14 6.5Z" stroke="#14110d" stroke-width="1.8" stroke-linejoin="round" />
  <circle cx="14" cy="13" r="2.5" stroke="#14110d" stroke-width="1.5" />
  <path d="M14 15.5V18" stroke="#14110d" stroke-width="1.5" stroke-linecap="round" />
</svg>
