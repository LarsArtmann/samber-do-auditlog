---
export interface Props {
  title: string;
  subtitle?: string;
}

const { title, subtitle } = Astro.props;
---

<div class="text-center mb-12">
  <h2 class="text-[clamp(1.875rem,4vw,2.25rem)] font-bold text-text-primary mb-4">{title}</h2>
  {subtitle && <p class="text-lg text-text-muted mb-12">{subtitle}</p>}
</div>
